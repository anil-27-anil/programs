import java.util.ArrayList;
import java.util.List;
public class AlternatePrime {
    public static List<Integer> getAlternatePrimes(int n) {
        List<Integer> primes = new ArrayList<>();
        List<Integer> result = new ArrayList<>();
        for (int i = 2; i <= n; i++) {
            if (isPrime(i))
                primes.add(i);
        }
        for (int i = 0; i < primes.size(); i += 2) {
            result.add(primes.get(i));
        }
        return result;
    }
    private static boolean isPrime(int num) {
        if (num < 2) return false;
        for (int i = 2; i <= Math.sqrt(num); i++)
            if (num % i == 0) return false;
        return true;
    }
}




import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.Test;
import java.util.*;

public class AlternatePrimeTest {

    @Test
    void testAlternatePrimes() {
        List<Integer> expected = Arrays.asList(2, 5);
        assertEquals(expected, AlternatePrime.getAlternatePrimes(10));
    }
}
